      "id": "text-1",
      "pageId": "page-1",
      "type": "text",
      "x": 100,
      "y": 100,
      "w": 240,
      "h": 60,
      "zIndex": 1,
      "text": "Sample text"
    },
    {
      "id": "heading-1",
      "pageId": "page-1",
      "type": "heading",
      "x": 100,
      "y": 200,
      "w": 320,
      "h": 80,
      "zIndex": 2,
      "level": 1,
      "text": "Sample heading"
    },
    {
